<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:id="@+id/imageView8"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/belajarangka3"
        android:scaleType="fitXY"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Guideline Vertical -->

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/g1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.12"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/g2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.34"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/g3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.56"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/g4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.78"/>

    <!-- Guideline Horizontal -->

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.40"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.56"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.72"/>

    <!-- ================= BARIS 1 ================= -->

    <Button
        android:id="@+id/btn21"
        android:layout_width="74dp"
        android:layout_height="74dp"
        android:text="21"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F48FB1"
        app:layout_constraintStart_toStartOf="@id/g1"
        app:layout_constraintTop_toTopOf="@id/h1"/>

    <Button
        android:id="@+id/btn22"
        android:layout_width="74dp"
        android:layout_height="74dp"
        android:text="22"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#81C784"
        app:layout_constraintStart_toStartOf="@id/g2"
        app:layout_constraintTop_toTopOf="@id/h1"/>

    <Button
        android:id="@+id/btn23"
        android:layout_width="74dp"
        android:layout_height="74dp"
        android:text="23"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#64B5F6"
        app:layout_constraintStart_toStartOf="@id/g3"
        app:layout_constraintTop_toTopOf="@id/h1"/>

    <Button
        android:id="@+id/btn24"
        android:layout_width="74dp"
        android:layout_height="74dp"
        android:text="24"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#BA68C8"
        app:layout_constraintStart_toStartOf="@id/g4"
        app:layout_constraintTop_toTopOf="@id/h1"/>

    <!-- ================= BARIS 2 ================= -->

    <Button
        android:id="@+id/btn25"
        android:layout_width="74dp"
        android:layout_height="74dp"
        android:text="25"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFB74D"
        app:layout_constraintStart_toStartOf="@id/g1"
        app:layout_constraintTop_toTopOf="@id/h2"/>

    <Button
        android:id="@+id/btn26"
        android:layout_width="74dp"
        android:layout_height="74dp"
        android:text="26"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4DB6AC"
        app:layout_constraintStart_toStartOf="@id/g2"
        app:layout_constraintTop_toTopOf="@id/h2"/>

    <Button
        android:id="@+id/btn27"
        android:layout_width="74dp"
        android:layout_height="74dp"
        android:text="27"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#E57373"
        app:layout_constraintStart_toStartOf="@id/g3"
        app:layout_constraintTop_toTopOf="@id/h2"/>

    <Button
        android:id="@+id/btn28"
        android:layout_width="74dp"
        android:layout_height="74dp"
        android:text="28"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#AED581"
        app:layout_constraintStart_toStartOf="@id/g4"
        app:layout_constraintTop_toTopOf="@id/h2"/>

    <!-- ================= BARIS 3 ================= -->

    <Button
        android:id="@+id/btn29"
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:text="29"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#9575CD"
        app:layout_constraintStart_toStartOf="@id/g2"
        app:layout_constraintTop_toTopOf="@id/h3"/>

    <Button
        android:id="@+id/btn30"
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:text="30"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF8A65"
        app:layout_constraintStart_toStartOf="@id/g3"
        app:layout_constraintTop_toTopOf="@id/h3"/>

    <!-- Tombol bawah -->

    <Button
        android:id="@+id/btnKembali"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="20dp"
        android:text="KEMBALI"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="17sp"
        android:backgroundTint="#FFB74D"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnSelanjutnya"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_weight="1"/>

    <Button
        android:id="@+id/btnSelanjutnya"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:text="SELANJUTNYA"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="17sp"
        android:backgroundTint="#66BB6A"
        app:layout_constraintStart_toEndOf="@id/btnKembali"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_weight="1"/>

</androidx.constraintlayout.widget.ConstraintLayout>