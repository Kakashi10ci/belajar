<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:id="@+id/imageView17"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/kuis"
        android:scaleType="fitXY"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Guideline -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.20"/>

    <!-- Pertanyaan -->
    <TextView
        android:id="@+id/txtSoal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:background="#80000000"
        android:padding="20dp"
        android:text="Manakah kata yang memiliki&#10;jumlah huruf paling banyak?"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"

        app:layout_constraintTop_toTopOf="@id/topGuide"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Jawaban 1 -->
    <Button
        android:id="@+id/btnJawab1"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="36dp"

        android:text="BUKU"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4FC3F7"

        app:layout_constraintTop_toBottomOf="@id/txtSoal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Jawaban 2 -->
    <Button
        android:id="@+id/btnJawab2"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="18dp"

        android:text="PENSIL"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#81C784"

        app:layout_constraintTop_toBottomOf="@id/btnJawab1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Jawaban 3 -->
    <Button
        android:id="@+id/btnJawab3"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="18dp"

        android:text="MEJA"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFB74D"

        app:layout_constraintTop_toBottomOf="@id/btnJawab2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Jawaban 4 -->
    <Button
        android:id="@+id/btnJawab4"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="18dp"

        android:text="TAS"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#BA68C8"

        app:layout_constraintTop_toBottomOf="@id/btnJawab3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>