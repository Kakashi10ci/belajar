<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdminDashboardActivity">

    <!-- Background -->
    <ImageView
        android:id="@+id/btnAdmin"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/hasilkuis"
        android:scaleType="fitXY"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Judul -->
    <TextView
        android:id="@+id/txtJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DASHBOARD GURU"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#80000000"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <!-- Sub Judul -->
    <TextView
        android:id="@+id/txtSubJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Data Perkembangan Siswa"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="#80000000"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtJudul"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Card Pencarian -->
    <LinearLayout
        android:id="@+id/cardPencarian"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#CCFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/txtSubJudul"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp">

        <!-- Label Pencarian -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍 Cari Data Siswa"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="12dp"/>

        <!-- Input Pencarian -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etCariSiswa"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="Masukkan Nama Siswa"
                android:inputType="text"
                android:background="@android:drawable/editbox_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#999999"/>

            <Button
                android:id="@+id/btnCari"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:text="Cari"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2196F3"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Tombol Tampilkan Semua -->
        <Button
            android:id="@+id/btnTampilkanSemua"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#4CAF50"
            android:text="Tampilkan Semua Siswa"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <!-- Tombol List Siswa -->
        <Button
            android:id="@+id/btnListSiswa"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FF9800"
            android:text="📋 List Semua Siswa"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Card Hasil Pencarian -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardHasil"
        android:layout_width="340dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/cardPencarian"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnLihatHasilKuis"
        app:layout_constraintVertical_bias="0">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Nama Siswa -->
                <TextView
                    android:id="@+id/txtNamaSiswa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama: -"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#000000"/>

                <!-- Kelas -->
                <TextView
                    android:id="@+id/txtKelasSiswa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelas: -"
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:layout_marginTop="4dp"/>

                <!-- Status -->
                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: -"
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:layout_marginTop="4dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#CCCCCC"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Kemampuan Membaca -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖 Kemampuan Membaca"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#000000"/>

                <ProgressBar
                    android:id="@+id/progressMembacaAdmin"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#4CAF50"/>

                <TextView
                    android:id="@+id/txtPersenMembacaAdmin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:layout_marginTop="4dp"/>

                <!-- Kemampuan Berhitung -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔢 Kemampuan Berhitung"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:layout_marginTop="12dp"/>

                <ProgressBar
                    android:id="@+id/progressBerhitungAdmin"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#FF9800"/>

                <TextView
                    android:id="@+id/txtPersenBerhitungAdmin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:layout_marginTop="4dp"/>

                <!-- Nilai Rata-rata -->
                <TextView
                    android:id="@+id/txtRataRataAdmin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Nilai Rata-rata: -"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginTop="16dp"/>

                <!-- Badge -->
                <TextView
                    android:id="@+id/txtBadgeAdmin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏆 Badge: -"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- TOMBOL LIHAT HASIL KUIS (DI ATAS KEMBALI) -->
    <Button
        android:id="@+id/btnLihatHasilKuis"
        android:layout_width="250dp"
        android:layout_height="50dp"
        android:text="📊 Lihat Hasil Kuis"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:backgroundTint="#9C27B0"
        app:layout_constraintBottom_toTopOf="@id/btnKembali"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

    <!-- Tombol Kembali -->
    <Button
        android:id="@+id/btnKembali"
        android:layout_width="180dp"
        android:layout_height="55dp"
        android:text="KEMBALI"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="18sp"
        android:backgroundTint="#EF5350"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="30dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>