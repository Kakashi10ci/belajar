<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:id="@+id/imageView5"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/sukukata2"
        android:scaleType="fitXY"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= Guideline ================= -->

    <!-- Kolom -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gLeft"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gRight"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.62"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Baris -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h1"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.36"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h2"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.55"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h3"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.74"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- ================= BARIS 1 ================= -->

    <Button
        android:id="@+id/btnBoneka"
        android:layout_width="145dp"
        android:layout_height="68dp"
        android:text="BONEKA"
        android:textSize="21sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#81C784"
        app:layout_constraintStart_toStartOf="@id/gLeft"
        app:layout_constraintTop_toTopOf="@id/h1"/>

    <Button
        android:id="@+id/btnJaket"
        android:layout_width="145dp"
        android:layout_height="68dp"
        android:text="JAKET"
        android:textSize="21sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#64B5F6"
        app:layout_constraintStart_toStartOf="@id/gRight"
        app:layout_constraintTop_toTopOf="@id/h1"/>

    <!-- ================= BARIS 2 ================= -->

    <Button
        android:id="@+id/btnBaju"
        android:layout_width="145dp"
        android:layout_height="68dp"
        android:text="BAJU"
        android:textSize="21sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFB74D"
        app:layout_constraintStart_toStartOf="@id/gLeft"
        app:layout_constraintTop_toTopOf="@id/h2"/>

    <Button
        android:id="@+id/btnDompet"
        android:layout_width="145dp"
        android:layout_height="68dp"
        android:text="DOMPET"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#BA68C8"
        app:layout_constraintStart_toStartOf="@id/gRight"
        app:layout_constraintTop_toTopOf="@id/h2"/>

    <!-- ================= BARIS 3 ================= -->

    <Button
        android:id="@+id/btNKacamata"
        android:layout_width="176dp"
        android:layout_height="66dp"
        android:backgroundTint="#E57373"
        android:text="KACAMATA"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/gLeft"
        app:layout_constraintTop_toTopOf="@id/h3" />

    <Button
        android:id="@+id/btnBola"
        android:layout_width="145dp"
        android:layout_height="68dp"
        android:text="BOLA"
        android:textSize="21sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4DB6AC"
        app:layout_constraintStart_toStartOf="@id/gRight"
        app:layout_constraintTop_toTopOf="@id/h3"/>

    <!-- ================= Tombol Bawah ================= -->

    <Button
        android:id="@+id/btnKembali"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="20dp"
        android:text="KEMBALI"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFB74D"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnSelanjutnya"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <Button
        android:id="@+id/btnSelanjutnya"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:text="SELANJUTNYA"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#66BB6A"
        app:layout_constraintStart_toEndOf="@id/btnKembali"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>