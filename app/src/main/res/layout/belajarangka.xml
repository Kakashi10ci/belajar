<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/belajarangka"
        android:scaleType="fitXY"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ===================== GUIDELINE ===================== -->

    <!-- Kolom -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/g1"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.08"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/g2"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.31"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/g3"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.54"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/g4"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.77"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Baris -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h1"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.40"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h2"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.58"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h3"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.75"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- ===================== BARIS 1 ===================== -->

    <Button
        android:id="@+id/btn1"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="1"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F48FB1"
        app:layout_constraintStart_toStartOf="@id/g1"
        app:layout_constraintTop_toTopOf="@id/h1"/>

    <Button
        android:id="@+id/btn2"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="2"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#81C784"
        app:layout_constraintStart_toStartOf="@id/g2"
        app:layout_constraintTop_toTopOf="@id/h1"/>

    <Button
        android:id="@+id/btn3"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="3"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#64B5F6"
        app:layout_constraintStart_toStartOf="@id/g3"
        app:layout_constraintTop_toTopOf="@id/h1"/>

    <Button
        android:id="@+id/btn4"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="4"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#BA68C8"
        app:layout_constraintStart_toStartOf="@id/g4"
        app:layout_constraintTop_toTopOf="@id/h1"/>

    <!-- ===================== BARIS 2 ===================== -->

    <Button
        android:id="@+id/btn5"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="5"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFB74D"
        app:layout_constraintStart_toStartOf="@id/g1"
        app:layout_constraintTop_toTopOf="@id/h2"/>

    <Button
        android:id="@+id/btn6"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="6"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4DB6AC"
        app:layout_constraintStart_toStartOf="@id/g2"
        app:layout_constraintTop_toTopOf="@id/h2"/>

    <Button
        android:id="@+id/btn7"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="7"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#E57373"
        app:layout_constraintStart_toStartOf="@id/g3"
        app:layout_constraintTop_toTopOf="@id/h2"/>

    <Button
        android:id="@+id/btn8"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="8"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#AED581"
        app:layout_constraintStart_toStartOf="@id/g4"
        app:layout_constraintTop_toTopOf="@id/h2"/>

    <!-- ===================== BARIS 3 ===================== -->

    <Button
        android:id="@+id/btn9"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:text="9"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#9575CD"
        app:layout_constraintStart_toStartOf="@id/g2"
        app:layout_constraintTop_toTopOf="@id/h3"/>

    <Button
        android:id="@+id/btn10"
        android:layout_width="82dp"
        android:layout_height="72dp"
        android:text="10"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF8A65"
        app:layout_constraintStart_toStartOf="@id/g3"
        app:layout_constraintTop_toTopOf="@id/h3"/>

    <!-- ===================== TOMBOL BAWAH ===================== -->

    <Button
        android:id="@+id/btnKembali"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="20dp"
        android:text="KEMBALI"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFB74D"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnSelanjutnya"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <Button
        android:id="@+id/btnSelanjutnya"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:text="SELANJUTNYA"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#66BB6A"
        app:layout_constraintStart_toEndOf="@id/btnKembali"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>