<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MariBelajar"
        tools:targetApi="31">

        <!-- HALAMAN LOGIN sebagai LAUNCHER (Halaman Utama) -->
        <activity
            android:name=".LoginUserAdmin"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Halaman Login User & Admin -->
        <activity
            android:name=".LoginUser"
            android:exported="false" />
        <activity
            android:name=".LoginAdmin"
            android:exported="false" />

        <!-- Halaman Beranda (User) -->
        <activity
            android:name=".BerandaActivity"
            android:exported="false" />

        <!-- Halaman Admin Dashboard -->
        <activity
            android:name=".AdminDashboardActivity"
            android:exported="false" />

        <!-- LEVEL INTRO (TAMBAHKAN INI) -->
        <activity
            android:name=".IntroKuislvl1"
            android:exported="false" />
        <activity
            android:name=".IntroKuislvl2"
            android:exported="false" />
        <activity
            android:name=".IntroKuislvl3"
            android:exported="false" />

        <!-- Activity Belajar -->
        <activity android:name=".BelajarAngka" />
        <activity android:name=".BelajarAngka2" />
        <activity android:name=".BelajarAngka3" />

        <!-- Activity Membaca & Berhitung -->
        <activity android:name=".MembacaActivity" />
        <activity android:name=".BerhitungActivity" />

        <!-- Activity Huruf -->
        <activity android:name=".HurufActivity" />
        <activity android:name=".HurufActivity2" />
        <activity android:name=".HurufActivity3" />

        <!-- Activity Kata -->
        <activity android:name=".KataActivity" />
        <activity android:name=".KataActivity2" />
        <activity android:name=".KataActivity3" />

        <!-- Activity Penambahan -->
        <activity android:name=".Penambahan" />
        <activity android:name=".Penambahan2" />
        <activity android:name=".Penambahan3" />

        <!-- Activity Pengurangan -->
        <activity android:name=".Pengurangan" />
        <activity android:name=".Pengurangan2" />
        <activity android:name=".Pengurangan3" />

        <!-- Activity Kuis Level -->
        <activity android:name=".KuisLvl1" />
        <activity android:name=".KuisLvl2" />
        <activity android:name=".KuisLvl3" />

        <!-- Activity Kuis -->
        <activity android:name=".Kuis2" />
        <activity android:name=".Kuis3" />
        <activity android:name=".Kuis4" />
        <activity android:name=".Kuis5" />
        <activity android:name=".Kuis6" />
        <activity android:name=".Kuis7" />
        <activity android:name=".Kuis8" />
        <activity android:name=".Kuis9" />
        <activity android:name=".Kuis11" />
        <activity android:name=".Kuis12" />
        <activity android:name=".Kuis13" />
        <activity android:name=".Kuis14" />

        <!-- Activity Hasil & Perkembangan -->
        <activity android:name=".HasilKuis" />

        <!-- Tambahkan Service -->
        <service
            android:name=".MusicService"
            android:enabled="true"
            android:exported="false" />

    </application>

</manifest>